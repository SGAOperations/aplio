{
  "permissions": {
    "allow": [
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx shadcn *)",
      "Bash(npx shadcn@latest *)",
      "Bash(npx shadcn@* *)",
      "Edit(.temp/**)",
      "Write(.temp/**)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:ui.shadcn.com)",
      "WebFetch(domain:code.claude.com)"
    ],
    "deny": [
      "Bash(gh pr merge *)",
      "Bash(gh issue delete *)",
      "Bash(gh repo delete *)",
      "Bash(gh auth *)",
      "Bash(git push * main)",
      "Bash(git push origin main)",
      "Bash(npm publish *)",
      "Bash(npm login *)",
      "Bash(npm adduser *)",
      "Bash(npx vercel *)",
      "Bash(vercel *)"
    ]
  },
  "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" }
}
